# MongoDB Connection
MONGODB_URI=mongodb://admin:password@localhost:27017/myapp?authSource=admin

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=totally-unique-backend-id

# Azure AI Vision (Tags)
AZURE_VISION_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_VISION_KEY=your-azure-vision-key
AZURE_VISION_FEATURES=Tags

# Image -> produce item taxonomy match threshold
ITEM_MATCH_THRESHOLD=0.6

# Glean Agent (LLM) — optional; without it, farmer gets regex fallback and restaurant still gets real listings
# Free options (use one):
# GROQ_API_KEY=gsk_...          # Free tier: https://console.groq.com — uses llama-3.1-8b-instant
# OPENROUTER_API_KEY=sk-or-...  # Free models: https://openrouter.ai — e.g. meta-llama/llama-3.2-3b-instruct:free
# Paid:
# OPENAI_API_KEY=sk-...
# Override model (optional): GLEAN_LLM_MODEL=llama-3.1-8b-instant
